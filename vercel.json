{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" },
    { "src": "*.jpeg", "use": "@vercel/static" },
    { "src": "*.jpg", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" },
    { "src": "*.ico", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/cron-trigger", "dest": "api/cron-trigger.js" },
    { "src": "/api/(.*)", "dest": "https://ideal-code-tracker-backend.onrender.com/api/$1" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "crons": [
    {
      "path": "/api/cron-trigger",
      "schedule": "30 15 * * *"
    }
  ]
}
